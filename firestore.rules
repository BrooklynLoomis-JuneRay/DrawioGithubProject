rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Projects
    match /projects/{projectId} {
      // Allow read/write if the user is in the collaborators array
      allow read, update: if request.auth != null && request.auth.uid in resource.data.collaborators;
      
      // Only the owner can delete or rename (though rename is currently just an update)
      allow delete: if request.auth != null && request.auth.uid == resource.data.owner;
      
      // Anyone logged in can create a project
      allow create: if request.auth != null;

      // Elements Sub-collection
      match /elements/{elementId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators;
        
        allow write: if request.auth != null 
          && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators
          && (
            // Basic Validation
            request.resource.data.x is number &&
            request.resource.data.y is number &&
            (request.resource.data.width == null || request.resource.data.width >= 0) &&
            (request.resource.data.height == null || request.resource.data.height >= 0)
          );
      }

      // Presence Sub-collection (for cursors)
      match /presence/{userId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.collaborators;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
